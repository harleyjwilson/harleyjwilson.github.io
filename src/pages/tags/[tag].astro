---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION } from "../../consts";
import Nav from "../../components/Nav.astro";
import { formatDateShort } from "../../utils";

export async function getStaticPaths() {
  const allPosts = (await getCollection("blog")).sort(
    (b, a) => a.data.published.valueOf() - b.data.published.valueOf(),
  );

  const uniqueTags = [
    ...new Set(
      allPosts
        .flatMap((post) => post.data.tags ?? [])
    ),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter(
      (post) => post.data.tags?.includes(tag),
    );
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params as { tag: string };
const { posts } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={tag} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header>
      <Nav />
    </Header>
    <main>
      <h3 class="filter-title">Filtering for "{tag}"</h3>
      <a href="/blog" class="remove-filter">Remove filter</a>
      <ul class="blog-posts">
        {
          posts.map(
            (post: { data: { published: Date; title: unknown }; slug: any }) => (
              <li>
                <span>
                  <i>
                    <time datetime={post.data.published.toISOString()}>
                      {formatDateShort(post.data.published)}
                    </time>
                  </i>
                </span>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </li>
            )
          )
        }
      </ul>
    </main>
  </body>
</html>
